# Contact-form e-mail configuration. Copy to .env.local and fill in.

# Recipient of form submissions (production: peterka.kolektiv@email.cz)
CONTACT_TO=peterka.kolektiv@email.cz

# "From" identity on the notification e-mail
MAIL_FROM=peterka.kolektiv@email.cz
MAIL_FROM_NAME=Peterka & Kolektiv

# SMTP transport (any provider). On Deployik these are provisioned by the
# Integrations → Email page (Webglobe SMTP); locally use your mailbox SMTP.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Optional: reCAPTCHA v3 spam protection
RECAPTCHA_SECRET=
RECAPTCHA_SCORE_THRESHOLD=0.5
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
